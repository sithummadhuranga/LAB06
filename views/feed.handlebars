<section class="feed-hero container">
  <h1 class="feed-title">Latest Posts</h1>
  <p class="feed-subtitle">
    {{totalPosts}} post{{#unless (eq totalPosts 1)}}s{{/unless}} &mdash;
    page {{pagination.page}} of {{pagination.totalPages}}
  </p>
</section>

<div class="container">
  {{#if posts.length}}
    <ol class="posts-grid" aria-label="Post list">
      {{#each posts}}
        <li class="post-card" id="post-{{this.id}}">
          {{#if this.imageUrl}}
            <a href="/post/{{this.id}}" class="post-card__img-wrap" style="display: block;">
              <img
                src="{{this.imageUrl}}"
                alt="Cover image for: {{this.title}}"
                class="post-card__img"
                loading="lazy"
              />
            </a>
          {{/if}}
          <div class="post-card__body">
            <div class="post-card__meta">
              <span class="avatar" aria-label="Author avatar">
                {{upper this.author.username}}
              </span>
              <span class="author-name">{{this.author.username}}</span>
              <time class="post-date" datetime="{{this.createdAt}}">
                {{formatDate this.createdAt}}
              </time>
            </div>
            <h2 class="post-card__title">
              <a href="/post/{{this.id}}" style="color: inherit; text-decoration: none;">
                {{this.title}}
              </a>
            </h2>
            <p class="post-card__excerpt">{{excerpt this.content}}</p>
            <div class="post-card__footer">
              <span class="badge badge--likes">❤&nbsp;{{this.likes.length}}</span>
              <span class="badge badge--id">ID: {{this.id}}</span>
            </div>
          </div>
        </li>
      {{/each}}
    </ol>

    <nav class="pagination" aria-label="Post page navigation">
      {{#if pagination.hasPrev}}
        <a href="/feed?page={{dec pagination.page}}" class="btn btn--outline" id="prev-page">← Prev</a>
      {{else}}
        <span class="btn btn--outline btn--disabled">← Prev</span>
      {{/if}}

      <span class="pagination-info">{{pagination.page}} / {{pagination.totalPages}}</span>

      {{#if pagination.hasNext}}
        <a href="/feed?page={{inc pagination.page}}" class="btn btn--outline" id="next-page">Next →</a>
      {{else}}
        <span class="btn btn--outline btn--disabled">Next →</span>
      {{/if}}
    </nav>

  {{else}}
    <div class="empty-state">
      <p class="empty-icon" aria-hidden="true">📭</p>
      <h2>No posts yet</h2>
      <p>Click "Create Post" to be the first to share something!</p>
    </div>
  {{/if}}
</div>

<!-- Create Post Modal -->
<div id="createPostModal" class="modal-backdrop" style="display: none;">
  <div class="modal-content auth-box">
    <h2>Create New Post</h2>
    <form id="createPostForm" class="auth-form" enctype="multipart/form-data">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" required placeholder="What's on your mind?" />
      </div>
      <div class="form-group">
        <label for="content">Content</label>
        <textarea id="content" name="content" required placeholder="Write your post here..." rows="4"></textarea>
      </div>
      <div class="form-group">
        <label for="image">Image (Optional)</label>
        <input type="file" id="image" name="image" accept="image/png, image/jpeg, image/webp" />
      </div>
      <div id="createPostError" class="auth-error-msg" style="display: none;"></div>
      <div style="display: flex; gap: 1rem; margin-top: 1rem;">
        <button type="submit" class="btn btn--primary" style="flex: 1;">Post</button>
        <button type="button" id="cancelPostBtn" class="btn btn--outline" style="flex: 1;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/feed.js"></script>
